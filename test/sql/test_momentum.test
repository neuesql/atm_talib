# name: test/sql/test_momentum.test
# description: Tests for momentum indicators (RSI, WILLR, CCI) — patterns P1 and P3
# group: [talib]

require talib

statement ok
CREATE TABLE ohlc AS
SELECT * FROM (VALUES
    ('2024-01-01'::DATE, 100.0, 105.0, 95.0,  102.0),
    ('2024-01-02'::DATE, 102.0, 108.0, 101.0, 107.0),
    ('2024-01-03'::DATE, 107.0, 110.0, 104.0, 106.0),
    ('2024-01-04'::DATE, 106.0, 112.0, 105.0, 111.0),
    ('2024-01-05'::DATE, 111.0, 115.0, 109.0, 113.0),
    ('2024-01-08'::DATE, 113.0, 116.0, 110.0, 114.0),
    ('2024-01-09'::DATE, 114.0, 118.0, 112.0, 117.0),
    ('2024-01-10'::DATE, 117.0, 120.0, 115.0, 119.0)
) AS t(date, open, high, low, close);

# -------------------------------------------------------
# RSI — P1 pattern: (LIST<DOUBLE>, INTEGER) -> LIST<DOUBLE>
# -------------------------------------------------------

# RSI scalar: output length matches input length
query I
SELECT length(t_rsi([102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0], 5));
----
10

# RSI scalar: first (period) elements are NULL, rest are computed
query I
SELECT t_rsi([102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0], 5)[1] IS NULL;
----
true

query I
SELECT t_rsi([102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0], 5)[6] IS NOT NULL;
----
true

# RSI scalar: check a known value (period=5 on standard close prices)
query R
SELECT round(t_rsi([102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0], 5)[6], 4);
----
92.8571

# RSI plain aggregate (no OVER): returns single value from all rows
query R
SELECT round(ta_rsi(close, 3), 4) FROM ohlc;
----
97.2603

# RSI window function with period=3, window size=6
query R
SELECT round(ta_rsi(close, 3) OVER (
    ORDER BY date
    ROWS BETWEEN 5 PRECEDING AND CURRENT ROW
), 4) FROM ohlc;
----
NULL
NULL
NULL
90.9091
92.8571
93.8462
93.8462
100.0

# -------------------------------------------------------
# WILLR — P3 pattern: (LIST<DOUBLE> x3, INTEGER) -> LIST<DOUBLE>
# -------------------------------------------------------

# WILLR scalar: output length matches input length
query I
SELECT length(t_willr(
    [105.0, 108.0, 110.0, 112.0, 115.0, 116.0, 118.0],
    [95.0,  100.0, 101.0, 104.0, 109.0, 110.0, 112.0],
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0],
    3
));
----
7

# WILLR scalar: first (period-1) elements are NULL
query I
SELECT t_willr(
    [105.0, 108.0, 110.0, 112.0, 115.0, 116.0, 118.0],
    [95.0,  100.0, 101.0, 104.0, 109.0, 110.0, 112.0],
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0],
    3
)[1] IS NULL;
----
true

# WILLR scalar: period-th element is not NULL
query I
SELECT t_willr(
    [105.0, 108.0, 110.0, 112.0, 115.0, 116.0, 118.0],
    [95.0,  100.0, 101.0, 104.0, 109.0, 110.0, 112.0],
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0],
    3
)[3] IS NOT NULL;
----
true

# WILLR scalar: values should be in range [-100, 0]
query I
SELECT t_willr(
    [105.0, 108.0, 110.0, 112.0, 115.0, 116.0, 118.0],
    [95.0,  100.0, 101.0, 104.0, 109.0, 110.0, 112.0],
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0],
    3
)[4] BETWEEN -100.0 AND 0.0;
----
true

# WILLR plain aggregate: returns single scalar from all rows
query R
SELECT round(ta_willr(high, low, close, 3), 4) FROM ohlc;
----
-10.0

# WILLR window function with period=3, window size=5
query R
SELECT round(ta_willr(high, low, close, 3) OVER (
    ORDER BY date
    ROWS BETWEEN 4 PRECEDING AND CURRENT ROW
), 4) FROM ohlc;
----
NULL
NULL
-26.6667
-9.0909
-18.1818
-18.1818
-11.1111
-10.0

# -------------------------------------------------------
# CCI — P3 pattern: (LIST<DOUBLE> x3, INTEGER) -> LIST<DOUBLE>
# -------------------------------------------------------

# CCI scalar: output length matches input length
query I
SELECT length(t_cci(
    [105.0, 108.0, 110.0, 112.0, 115.0, 116.0, 118.0],
    [95.0,  100.0, 101.0, 104.0, 109.0, 110.0, 112.0],
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0],
    3
));
----
7

# CCI scalar: first (period-1) elements are NULL
query I
SELECT t_cci(
    [105.0, 108.0, 110.0, 112.0, 115.0, 116.0, 118.0],
    [95.0,  100.0, 101.0, 104.0, 109.0, 110.0, 112.0],
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0],
    3
)[2] IS NULL;
----
true

# CCI scalar: period-th element is not NULL
query I
SELECT t_cci(
    [105.0, 108.0, 110.0, 112.0, 115.0, 116.0, 118.0],
    [95.0,  100.0, 101.0, 104.0, 109.0, 110.0, 112.0],
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0],
    3
)[3] IS NOT NULL;
----
true

# CCI plain aggregate: returns single scalar from all rows
query R
SELECT round(ta_cci(high, low, close, 3), 4) FROM ohlc;
----
100.0

# CCI window function with period=3, window size=5
query R
SELECT round(ta_cci(high, low, close, 3) OVER (
    ORDER BY date
    ROWS BETWEEN 4 PRECEDING AND CURRENT ROW
), 4) FROM ohlc;
----
NULL
NULL
68.75
100.0
100.0
71.4286
100.0
100.0
