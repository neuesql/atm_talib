# name: test/sql/test_multi_output.test
# description: Test multi-output TA-Lib functions
# group: [talib]

require talib

# MACD: need enough data points (at least 26+9-1 = 34 for default params)
query I
SELECT length(t_macd(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0,
     121.0, 118.0, 115.0, 117.0, 120.0, 122.0, 125.0, 128.0,
     130.0, 127.0, 124.0, 126.0, 129.0, 131.0, 134.0, 137.0,
     140.0, 138.0, 135.0, 137.0, 140.0, 142.0, 145.0, 148.0,
     150.0, 147.0],
    12, 26, 9
));
----
34

# MACD: check struct fields are accessible
query I
SELECT (t_macd(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0,
     121.0, 118.0, 115.0, 117.0, 120.0, 122.0, 125.0, 128.0,
     130.0, 127.0, 124.0, 126.0, 129.0, 131.0, 134.0, 137.0,
     140.0, 138.0, 135.0, 137.0, 140.0, 142.0, 145.0, 148.0,
     150.0, 147.0],
    12, 26, 9
))[34].macd IS NOT NULL;
----
true

# MACD: first elements should be NULL (lookback period)
query I
SELECT (t_macd(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0,
     121.0, 118.0, 115.0, 117.0, 120.0, 122.0, 125.0, 128.0,
     130.0, 127.0, 124.0, 126.0, 129.0, 131.0, 134.0, 137.0,
     140.0, 138.0, 135.0, 137.0, 140.0, 142.0, 145.0, 148.0,
     150.0, 147.0],
    12, 26, 9
))[1].macd IS NULL;
----
true

# BBANDS
query I
SELECT length(t_bbands(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0],
    5, 2.0, 2.0, 0
));
----
10

# BBANDS: struct fields accessible
query I
SELECT (t_bbands(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0],
    5, 2.0, 2.0, 0
))[5].upper IS NOT NULL;
----
true

# AROON
query I
SELECT length(t_aroon(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0],
    [100.0, 105.0, 104.0, 109.0, 111.0, 112.0, 115.0, 117.0, 119.0, 116.0],
    5
));
----
10

# AROON: struct fields
query I
SELECT (t_aroon(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0],
    [100.0, 105.0, 104.0, 109.0, 111.0, 112.0, 115.0, 117.0, 119.0, 116.0],
    5
))[10].aroon_up IS NOT NULL;
----
true

# STOCH
query I
SELECT length(t_stoch(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0,
     115.0, 117.0, 120.0, 122.0, 125.0, 128.0, 130.0, 127.0, 124.0, 126.0],
    [100.0, 105.0, 104.0, 109.0, 111.0, 112.0, 115.0, 117.0, 119.0, 116.0,
     113.0, 115.0, 118.0, 120.0, 123.0, 126.0, 128.0, 125.0, 122.0, 124.0],
    [101.0, 106.0, 105.0, 110.0, 112.0, 113.0, 116.0, 118.0, 120.0, 117.0,
     114.0, 116.0, 119.0, 121.0, 124.0, 127.0, 129.0, 126.0, 123.0, 125.0],
    5, 3, 0, 3, 0
));
----
20

# MINMAX
query I
SELECT length(t_minmax(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0],
    5
));
----
10

# MINMAX: struct fields
query I
SELECT (t_minmax(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0],
    5
))[10].min IS NOT NULL;
----
true

# MAMA
query I
SELECT length(t_mama(
    [102.0, 107.0, 106.0, 111.0, 113.0, 114.0, 117.0, 119.0, 121.0, 118.0,
     115.0, 117.0, 120.0, 122.0, 125.0, 128.0, 130.0, 127.0, 124.0, 126.0,
     129.0, 131.0, 134.0, 137.0, 140.0, 138.0, 135.0, 137.0, 140.0, 142.0,
     145.0, 148.0, 150.0, 147.0, 144.0, 146.0, 149.0, 151.0, 154.0, 157.0],
    0.5, 0.05
));
----
40

